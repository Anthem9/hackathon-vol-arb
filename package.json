{
  "name": "hackathon-vol-arb",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "turbo dev --parallel",
    "dev:hybrid": "DATA_MODE=hybrid WEB_PORT=${WEB_PORT:-3001} turbo dev --parallel",
    "db:backup": "node scripts/db-backup.mjs",
    "db:migrate": "pnpm --filter @vol-arb/api db:migrate",
    "db:restore": "node scripts/db-restore.mjs",
    "db:restore:check": "node scripts/db-restore-check.mjs",
    "env:check": "node scripts/env-check.mjs",
    "btc5m:orderbook:collector": "node scripts/btc5m-orderbook-collector.mjs status",
    "btc5m:orderbook:status": "node scripts/btc5m-orderbook-collector.mjs status",
    "btc5m:orderbook:plan": "node scripts/btc5m-orderbook-collector.mjs plan",
    "btc5m:orderbook:start": "node scripts/btc5m-orderbook-collector.mjs start",
    "btc5m:orderbook:start:auto": "node scripts/btc5m-orderbook-collector.mjs start-auto",
    "btc5m:orderbook:stop": "node scripts/btc5m-orderbook-collector.mjs stop",
    "btc5m:checkpoint": "node scripts/btc5m-checkpoint.mjs",
    "btc5m:checkpoint:status": "node scripts/btc5m-checkpoint.mjs --no-ga --summary-only",
    "btc5m:checkpoint:gate": "node scripts/btc5m-checkpoint.mjs --require-live-ready",
    "build": "turbo build",
    "lint": "turbo lint",
    "secret:scan": "node scripts/secret-scan.mjs",
    "test": "node scripts/env-check-boundary.test.mjs && node scripts/polymarket-credentials-cli.test.mjs && node scripts/btc5m-checkpoint-help.test.mjs && turbo test",
    "test:e2e": "playwright test",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  }
}
